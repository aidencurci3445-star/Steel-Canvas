# Environment variables for Steel
# Copy this file to .env and fill in your credentials
# NEVER commit .env to source control

# ExpressTURN TURN server credentials (free 1TB/month)
# Get yours at https://www.expressturn.com/
VITE_TURN_URL=turn:free.expressturn.com:9999
VITE_TURN_USERNAME=YOUR_TURN_USERNAME
VITE_TURN_CREDENTIAL=YOUR_TURN_CREDENTIAL

# Signaling server URL
VITE_SIGNALING_URL=wss://steelserver.onrender.com
